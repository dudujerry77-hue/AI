{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@titan/*": ["./apps/*/src/index.ts", "./engines/*/src/index.ts", "./packages/*/src/index.ts"]
    },
    "types": ["node", "vitest/globals"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["apps/**/*.ts", "engines/**/*.ts", "packages/**/*.ts", "runtime/**/*.ts", "tests/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
